AUTH_SECRET=your-auth-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# TiDB Serverless connection string
# Get from: TiDB Cloud Console → Connect → General → mysql2
DATABASE_URL=mysql://username:password@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/clipverse?ssl={"rejectUnauthorized":true}

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_LIFETIME_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

PROXY_URL=socks5h://user:pass@proxy-host:1080
TIKTOK_PROXY=socks5h://user:pass@us-proxy:1080
BILIBILI_PROXY=socks5h://user:pass@hk-proxy:1080
DOUYIN_PROXY=socks5h://user:pass@cn-proxy:1080
XIAOHONGSHU_PROXY=socks5h://user:pass@cn-proxy:1080

BGUTIL_POT_URL=http://bgutil-provider:4416
YOUTUBE_COOKIES_FILE=/secrets/youtube-cookies.txt
TIKTOK_COOKIES_FILE=/secrets/tiktok-cookies.txt
BILIBILI_COOKIES_FILE=/secrets/bilibili-cookies.txt
COOKIES_FILE=

# yt-dlp service (runs on your home server)
YTDLP_SERVICE_URL=http://localhost:8787
YTDLP_API_KEY=your-secret-api-key

# developer mode
ENABLE_DEVELOPER_MODE=true
DEVELOPER_REST_ALLOWED_PLANS=lifetime,team
DEVELOPER_MCP_ALLOWED_PLANS=lifetime,team
